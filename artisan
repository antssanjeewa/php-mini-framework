#!/usr/bin/env php
<?php

require_once __DIR__ . '/vendor/autoload.php';
$app = require_once __DIR__ . '/bootstrap/app.php';

$command = $argv[1] ?? null;
$parts = explode(':', $command);
$baseCommand = $parts[0];
$action = $parts[1] ?? null;

$commands = [
  'migrate' => \App\Console\Commands\MigrateCommand::class,
  'make' => \App\Console\Commands\MakeCommand::class,
];

if (!isset($commands[$baseCommand])) {
  echo "\033[31m Unknown command!\033[0m" . PHP_EOL;
  exit(1);
}

$commandClass = $commands[$baseCommand];
$command = new $commandClass();
$command->execute($action, array_slice($argv, 2));