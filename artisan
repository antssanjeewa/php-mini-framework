#!/usr/bin/env php
<?php

require_once __DIR__ . '/vendor/autoload.php';
$app = require_once __DIR__ . '/bootstrap/app.php';

$command = $argv[1] ?? null;

if ($command === 'migrate') {
  echo "Starting migrations..." . PHP_EOL;

  $file = 'm0001_create_users_table.php';

  require_once base_path('/database/migrations/' . $file);

  try {
    $className = pathinfo($file, PATHINFO_FILENAME);
    echo "Applying: $className" . PHP_EOL;

    $migration = new $className();
    $migration->up();

    echo "Successfully migrated!" . PHP_EOL;

  } catch (\Throwable $e) {
    echo "❌ Migration Failed!" . PHP_EOL;
    echo "📁 File: " . $file . PHP_EOL;
    echo "💬 Error Message: " . $e->getMessage() . PHP_EOL;
    echo "📍 Line: " . $e->getLine() . PHP_EOL;
    exit(1);
  }
}

